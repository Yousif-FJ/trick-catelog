# Tricks Catalog - Environment Configuration

# Google Sheets API Configuration
# Get your Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
# The document must be public.
GOOGLE_SHEETS_ID=

# Google Sheets & Drive API Key (server-side only, never exposed to client)
# Generate from: https://console.cloud.google.com
# Go to API & Services, Enable Google Drive API and then Google Sheet API 
# Then inside API & Services, go to Credentials, and create API key with access to the services we enabled in previous step.
GOOGLE_SHEETS_API_KEY=

# JWT Secret (for signing image URLs - use a strong random string in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
